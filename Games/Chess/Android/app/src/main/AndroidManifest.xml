<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLE is the cross-platform transport (see CLAUDE.md). Android 12+ split the
         old BLUETOOTH/BLUETOOTH_ADMIN perms into these runtime permissions. -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />
    <uses-feature android:name="android.hardware.vulkan.version" android:required="true" />

    <application
        android:label="@string/app_name"
        android:hasCode="true"
        android:allowBackup="false">

        <!-- Control passes to C++ (android_main in libonlychess.so). We subclass
             NativeActivity in Kotlin only so the BLE shim object is loaded and
             reachable from native code via JNI. -->
        <activity
            android:name=".OnlyChessActivity"
            android:exported="true"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout|density">
            <meta-data android:name="android.app.lib_name" android:value="onlychess" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
